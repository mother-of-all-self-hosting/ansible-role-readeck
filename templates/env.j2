TZ={{ readeck_environment_variables_tz }}

{#
  See: https://readeck.org/en/docs/configuration
#}

{% if readeck_database_type == 'postgres' %}
READECK_DATABASE_SOURCE=postgres://{{ readeck_database_username }}:{{ readeck_database_password }}@{{ readeck_database_hostname }}:{{ readeck_database_port }}/{{ readeck_database_name }}
{% endif %}

READECK_MAIL_HOST={{ readeck_environment_variables_readeck_mail_host }}
READECK_MAIL_PORT={{ readeck_environment_variables_readeck_mail_port }}
READECK_MAIL_USERNAME={{ readeck_environment_variables_readeck_mail_username }}
READECK_MAIL_PASSWORD={{ readeck_environment_variables_readeck_mail_password }}
READECK_MAIL_INSECURE={{ readeck_environment_variables_readeck_mail_insecure | to_json }}
READECK_MAIL_ENCRYPTION={{ readeck_environment_variables_readeck_mail_encryption }}
READECK_MAIL_FROM={{ readeck_environment_variables_readeck_mail_from }}
READECK_MAIL_FROMNOREPLY={{ readeck_environment_variables_readeck_mail_fromnoreply }}

{{ readeck_environment_variables_additional_variables }}
